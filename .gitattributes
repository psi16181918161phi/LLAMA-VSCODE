* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Source files
*.js text
*.ts text
*.tsx text
*.jsx text
*.json text
*.yml text
*.yaml text
*.md text
*.txt text
*.css text
*.scss text
*.html text
*.xml text

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text

# Archives / binaries
*.zip binary
*.gz binary
*.7z binary
*.pdf binary
*.exe binary
*.dll binary
