{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/llama-vscode/model-profile.schema.json",
    "title": "LlamaVscodeModelProfile",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "name",
        "hf_repo",
        "hf_file",
        "model_path",
        "ctx_size",
        "gpu_layers",
        "threads",
        "notes"
    ],
    "properties": {
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
        },
        "hf_repo": {
            "type": "string",
            "pattern": "^[^/]+/[^/]+$"
        },
        "hf_file": {
            "type": "string",
            "pattern": "(?i)\\.gguf$"
        },
        "model_path": {
            "type": "string",
            "minLength": 3
        },
        "ctx_size": {
            "type": "integer",
            "minimum": 256,
            "maximum": 32768
        },
        "gpu_layers": {
            "type": "integer",
            "minimum": 0,
            "maximum": 200
        },
        "threads": {
            "type": "integer",
            "minimum": 1,
            "maximum": 128
        },
        "notes": {
            "type": "string",
            "minLength": 0,
            "maxLength": 500
        }
    }
}